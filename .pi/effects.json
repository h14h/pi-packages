{
  "$schema": "./packages/effect-mode/schemas/effects.schema.json",
  "effects": [
    {
      "id": "git-state",
      "description": "Concise local git state snapshot for this pi-packages workspace",
      "command": "node packages/effect-mode/scripts/git-state.mjs",
      "ttlMs": 0,
      "timeoutMs": 2000,
      "maxBytes": 12000,
      "options": {
        "remoteMode": "background",
        "remoteTtlMs": 900000,
        "remoteErrorTtlMs": 300000,
        "remoteTimeoutMs": 10000,
        "remoteLockTtlMs": 120000
      }
    }
  ]
}
