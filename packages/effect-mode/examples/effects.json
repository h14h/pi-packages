{
  "$schema": "../schemas/effects.schema.json",
  "effects": [
    {
      "id": "git-status",
      "description": "Current git branch and working tree status",
      "command": "node packages/effect-mode/scripts/git-state.mjs",
      "ttlMs": 0,
      "timeoutMs": 2000,
      "maxBytes": 12000,
      "options": {
        "remoteMode": "background",
        "remoteTtlMs": 900000,
        "remoteErrorTtlMs": 300000,
        "remoteTimeoutMs": 15000
      }
    },
    {
      "id": "workspace-files",
      "description": "Top-level workspace files",
      "command": "find . -maxdepth 2 -type f | sort | head -80",
      "ttlMs": 30000,
      "maxBytes": 8000
    }
  ]
}
